# ============================================================
# SECRETS & CREDENTIALS — Ne jamais committer ces fichiers
# ============================================================
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ============================================================
# PYTHON
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
*.pyc
.mypy_cache/
.ruff_cache/

# ============================================================
# NODE.JS / REACT
# ============================================================
node_modules/
dist/
build/
.next/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage/
.eslintcache

# ============================================================
# TERRAFORM — CRITIQUE : les tfstate contiennent des secrets
# ============================================================
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfvars
# Garder le fichier exemple
!example.tfvars
crash.log
override.tf
override.tf.json

# ============================================================
# DOCKER
# ============================================================
.docker/
docker-compose.override.yml

# ============================================================
# OS & ÉDITEURS
# ============================================================
# Windows
Thumbs.db
Desktop.ini
ehthumbs.db

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code (garder les configs partagées, ignorer les perso)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-snippets
!.vscode/extensions.json
!.vscode/tasks.json

# JetBrains / PyCharm
.idea/
*.iml
*.iws

# ============================================================
# LOGS & DONNÉES DE RUN
# ============================================================
logs/
*.log
*.log.*
audit_logs/
/tmp/

# ============================================================
# MONITORING — Ne pas committer les données de métriques
# ============================================================
monitoring/grafana/data/
monitoring/prometheus/data/

# ============================================================
# JENKINS
# ============================================================
jenkins/workspace/
jenkins/.jenkins/
